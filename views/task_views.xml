<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Formulario -->
    <record id="view_task_manager_form" model="ir.ui.view">
        <field name="name">task.manager.form</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <form string="Tarea">
                <header>
                    <button name="action_start"
                            string="Iniciar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'backlog'"/>
                    <button name="action_review"
                            string="En Revisión"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_done"
                            string="Completar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'review'"/>
                    <button name="action_reset"
                            string="Reiniciar"
                            type="object"
                            invisible="state == 'backlog'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="backlog,in_progress,review,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="responsible_id"/>
                        <field name="priority"/>
                        <field name="deadline"/>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="description" placeholder="Describe la tarea..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vista Lista -->
    <record id="view_task_manager_list" model="ir.ui.view">
        <field name="name">task.manager.list</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <list string="Tareas">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="priority"/>
                <field name="deadline"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Vista Kanban -->
    <record id="view_task_manager_kanban" model="ir.ui.view">
        <field name="name">task.manager.kanban</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="priority"/>
                <field name="deadline"/>
                <field name="state"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_card #{record.priority.raw_value == '2' ? 'border-danger' : record.priority.raw_value == '1' ? 'border-warning' : ''}">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="responsible_id"/>
                                <br/>
                                <span>📅 <field name="deadline"/></span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <field name="priority" widget="priority"/>
                                <span t-if="record.priority.raw_value == '2'" class="badge text-bg-danger ms-1">Urgente</span>
                                <span t-if="record.priority.raw_value == '1'" class="badge text-bg-warning ms-1">Importante</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_task_manager" model="ir.actions.act_window">
        <field name="name">Tareas</field>
        <field name="res_model">task.manager</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                ¡Crea tu primera tarea!
            </p>
        </field>
    </record>

</odoo>